// Лабораторная работа 1
// Часть 1: два фактора

clear;
clc;

// Параметры модели
beta0 = 4;
beta1 = 4;
beta2 = -3;
beta12 = 3;

// Точка эксперимента
X1 = 50;
X2 = 60;

// Стандартное отклонение помехи
sigma = 0.05;

// Количество опытов
m = 10;

// Массив для результатов
Y = zeros(m, 1);

// Вычисление детерминированной части
phi = beta0 + beta1*X1 + beta2*X2 + beta12*X1*X2;

// Проведение опытов
for i = 1:m
    e = grand(1, 1, "nor", 0, sigma); // случайная помеха
    Y(i) = phi + e;
end

// Вывод результатов
disp("Результаты эксперимента (2 фактора):");
disp("Детерминированная часть φ(X) = " + string(phi));
disp("Результаты опытов Y:");
disp(Y);

// Часть 2: три фактора

// Параметры модели
beta0_3 = 4;
beta1_3 = 4;
beta2_3 = -3;
beta3_3 = -4;
beta12_3 = 3;
beta13_3 = 0;
beta23_3 = -2;
beta123_3 = 0;

// Точка эксперимента
X1_3 = 50;
X2_3 = 60;
X3_3 = 50;

// Стандартное отклонение помехи
sigma_3 = 0.05;

// Массив для результатов
Y_3 = zeros(m, 1);

// Вычисление детерминированной части
phi_3 = beta0_3 + beta1_3*X1_3 + beta2_3*X2_3 + beta3_3*X3_3 + ...
        beta12_3*X1_3*X2_3 + beta13_3*X1_3*X3_3 + beta23_3*X2_3*X3_3 + ...
        beta123_3*X1_3*X2_3*X3_3;

// Проведение опытов
for i = 1:m
    e = grand(1, 1, "nor", 0, sigma_3);
    Y_3(i) = phi_3 + e;
end

// Вывод результатов
disp("Результаты эксперимента (3 фактора):");
disp("Детерминированная часть φ(X) = " + string(phi_3));
disp("Результаты опытов Y:");
disp(Y_3);

// Обработка результатов для двух факторов
y_mean = mean(Y);
y_var = variance(Y);
m = length(Y);

// Доверительный интервал для мат. ожидания (t-критерий Стьюдента)
alpha = 0.05;
t = cdft("T", m-1, 1-alpha/2, alpha/2); // двусторонний квантиль
disp("Квантиль: " + string(t));

delta = t * sqrt(y_var / m);
disp("Квантиль: " + string(delta));
CI_mean = [y_mean - delta, y_mean + delta];

// Доверительный интервал для дисперсии (χ²-критерий)
chi2_low = cdfchi("X", m-1, alpha/2, 1-alpha/2);
chi2_up = cdfchi("X", m-1, 1-alpha/2, alpha/2);
CI_var = [(m-1)*y_var/chi2_up, (m-1)*y_var/chi2_low];

// Вывод результатов
disp("=== Обработка результатов (2 фактора) ===");
disp("Выборочное среднее: " + string(y_mean));
disp("Выборочная дисперсия: " + string(y_var));
disp("Доверительный интервал для мат. ожидания (95%):");
disp(CI_mean);
disp("Доверительный интервал для дисперсии (95%):");
disp(CI_var);

//Часть 3: Обработка результатов для трех факторов
y_mean_3 = mean(Y_3);
y_var_3 = variance(Y_3);

// Аналогичные вычисления для трех факторов
delta_3 = t * sqrt(y_var_3 / m);
CI_mean_3 = [y_mean_3 - delta_3, y_mean_3 + delta_3];
CI_var_3 = [(m-1)*y_var_3/chi2_up, (m-1)*y_var_3/chi2_low];

disp("=== Обработка результатов (3 фактора) ===");
disp("Выборочное среднее: " + string(y_mean_3));
disp("Выборочная дисперсия: " + string(y_var_3));
disp("Доверительный интервал для мат. ожидания (95%):");
disp(CI_mean_3);
disp("Доверительный интервал для дисперсии (95%):");
disp(CI_var_3);
