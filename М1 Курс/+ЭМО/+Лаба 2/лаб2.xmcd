							<ml:id xml:space="preserve">cod2_to_grey</ml:id>
							<ml:boundVars>
								<ml:id xml:space="preserve">cod2Vector</ml:id>
							</ml:boundVars>
						</ml:function>
						<ml:program>
							<ml:localDefine>
								<ml:id xml:space="preserve">rows</ml:id>
								<ml:apply>
									<ml:id xml:space="preserve">rows</ml:id>
									<ml:id xml:space="preserve">cod2Vector</ml:id>
								</ml:apply>
							</ml:localDefine>
							<ml:ifThen>
								<ml:apply>
									<ml:greaterOrEqual/>
									<ml:apply>
										<ml:id xml:space="preserve">min</ml:id>
										<ml:id xml:space="preserve">cod2Vector</ml:id>
									</ml:apply>
									<ml:real>0</ml:real>
								</ml:apply>
								<ml:localDefine>
									<ml:id xml:space="preserve">negativity</ml:id>
									<ml:real>1</ml:real>
								</ml:localDefine>
							</ml:ifThen>
							<ml:otherwise>
								<ml:localDefine>
									<ml:id xml:space="preserve">negativity</ml:id>
									<ml:real>-1</ml:real>
								</ml:localDefine>
							</ml:otherwise>
							<ml:for>
								<ml:id xml:space="preserve">row</ml:id>
								<ml:range>
									<ml:real>1</ml:real>
									<ml:id xml:space="preserve">rows</ml:id>
								</ml:range>
								<ml:program>
									<ml:ifThen>
										<ml:apply>
											<ml:notEqual/>
											<ml:id xml:space="preserve">row</ml:id>
											<ml:real>1</ml:real>
										</ml:apply>
										<ml:localDefine>
											<ml:apply>
												<ml:indexer/>
												<ml:id xml:space="preserve">out</ml:id>
												<ml:id xml:space="preserve">row</ml:id>
											</ml:apply>
											<ml:apply>
												<ml:xor/>
												<ml:apply>
													<ml:absval/>
													<ml:apply>
														<ml:indexer/>
														<ml:id xml:space="preserve">cod2Vector</ml:id>
														<ml:apply>
															<ml:minus/>
															<ml:id xml:space="preserve">row</ml:id>
															<ml:real>1</ml:real>
														</ml:apply>
													</ml:apply>
												</ml:apply>
												<ml:apply>
													<ml:absval/>
													<ml:apply>
														<ml:indexer/>
														<ml:id xml:space="preserve">cod2Vector</ml:id>
														<ml:id xml:space="preserve">row</ml:id>
													</ml:apply>
												</ml:apply>
											</ml:apply>
										</ml:localDefine>
									</ml:ifThen>
									<ml:otherwise>
										<ml:localDefine>
											<ml:apply>
												<ml:indexer/>
												<ml:id xml:space="preserve">out</ml:id>
												<ml:id xml:space="preserve">row</ml:id>
											</ml:apply>
											<ml:apply>
												<ml:absval/>
												<ml:apply>
													<ml:indexer/>
													<ml:id xml:space="preserve">cod2Vector</ml:id>
													<ml:id xml:space="preserve">row</ml:id>
												</ml:apply>
											</ml:apply>
										</ml:localDefine>
									</ml:otherwise>
									<ml:localDefine>
										<ml:apply>
											<ml:indexer/>
											<ml:id xml:space="preserve">out</ml:id>
											<ml:id xml:space="preserve">row</ml:id>
										</ml:apply>
										<ml:apply>
											<ml:mult/>
											<ml:apply>
												<ml:indexer/>
												<ml:id xml:space="preserve">out</ml:id>
												<ml:id xml:space="preserve">row</ml:id>
											</ml:apply>
											<ml:id xml:space="preserve">negativity</ml:id>
										</ml:apply>
									</ml:localDefine>
								</ml:program>
							</ml:for>
							<ml:id xml:space="preserve">out</ml:id>
						</ml:program>
					</ml:define>
