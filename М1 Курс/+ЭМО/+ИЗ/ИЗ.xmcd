															<ml:apply>
																<ml:notEqual/>
																<ml:id xml:space="preserve">j</ml:id>
																<ml:apply>
																	<ml:minus/>
																	<ml:id xml:space="preserve">n</ml:id>
																	<ml:id xml:space="preserve">t</ml:id>
																</ml:apply>
															</ml:apply>
															<ml:localDefine>
																<ml:id xml:space="preserve">O22</ml:id>
																<ml:apply>
																	<ml:id xml:space="preserve">stack</ml:id>
