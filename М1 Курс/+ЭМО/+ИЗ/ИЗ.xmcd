					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="0" margin-right="0" text-indent="inherit" text-align="left" list-style-type="inherit" tabs="inherit">
							<b>
								<inlineAttr font-style="normal">Отбираем NOsob особей с геномом определяющим кратчайший путь </inlineAttr>
							</b>
						</p>
					</text>
				</region>
				<region region-id="280" left="390" top="2054.25" width="276.75" height="84.75" align-x="390" align-y="2064" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Входные данные:</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Pop2 — исходная популяция.</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Fit — вектор приспособленности.</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>NOsob — количество отбираемых особей.</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit"/>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Выходные данные:</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Pop — новая популяция после отбора.</b>
						</p>
					</text>
				</region>
				<region region-id="277" left="24" top="2084.25" width="286.5" height="64.5" align-x="163.5" align-y="2094" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">SELECTION</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">Pop2</ml:id>
									<ml:id xml:space="preserve">Fit</ml:id>
									<ml:id xml:space="preserve">NOsob</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve">M</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve">augment</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve">Pop2</ml:id>
											<ml:id xml:space="preserve">Fit</ml:id>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve">M</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve">csort</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve">M</ml:id>
											<ml:real>1</ml:real>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve">Pop</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve">sub</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve">M</ml:id>
											<ml:real>0</ml:real>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">NOsob</ml:id>
												<ml:real>1</ml:real>
											</ml:apply>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:id xml:space="preserve">Pop</ml:id>
							</ml:program>
						</ml:define>
					</math>
					<rendering item-idref="13"/>
				</region>
				<region region-id="283" left="12" top="2204.25" width="198.75" height="12" align-x="12" align-y="2214" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="0" text-align="inherit" list-style-type="none" tabs="inherit">
							<b>Сам генетический алгоритм</b>
						</p>
					</text>
				</region>
				<region region-id="98" left="6" top="2228.25" width="511.5" height="132.75" align-x="144" align-y="2238" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">GenAlg</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">Coord</ml:id>
									<ml:id xml:space="preserve">Epocha</ml:id>
									<ml:id xml:space="preserve">NOsob</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve">n</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve">rows</ml:id>
										<ml:id xml:space="preserve">Coord</ml:id>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve">Pop1</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve">NACHPOP</ml:id>
										<ml:sequence>
											<ml:id xml:space="preserve">n</ml:id>
											<ml:id xml:space="preserve">NOsob</ml:id>
										</ml:sequence>
									</ml:apply>
								</ml:localDefine>
								<ml:for>
									<ml:id xml:space="preserve">i</ml:id>
									<ml:range>
										<ml:real>1</ml:real>
										<ml:id xml:space="preserve">Epocha</ml:id>
									</ml:range>
									<ml:program>
										<ml:localDefine>
											<ml:id xml:space="preserve">Pop2</ml:id>
											<ml:apply>
												<ml:id xml:space="preserve">CROSS</ml:id>
												<ml:id xml:space="preserve">Pop1</ml:id>
											</ml:apply>
										</ml:localDefine>
										<ml:localDefine>
											<ml:id xml:space="preserve">Pop2</ml:id>
											<ml:apply>
												<ml:id xml:space="preserve">if</ml:id>
												<ml:sequence>
													<ml:apply>
														<ml:equal/>
														<ml:id xml:space="preserve">Pop2</ml:id>
														<ml:real>0</ml:real>
													</ml:apply>
													<ml:apply>
														<ml:id xml:space="preserve">stack</ml:id>
														<ml:sequence>
															<ml:id xml:space="preserve">Pop1</ml:id>
															<ml:apply>
																<ml:id xml:space="preserve">MUT</ml:id>
																<ml:id xml:space="preserve">Pop1</ml:id>
															</ml:apply>
														</ml:sequence>
													</ml:apply>
													<ml:apply>
														<ml:id xml:space="preserve">stack</ml:id>
														<ml:sequence>
															<ml:id xml:space="preserve">Pop1</ml:id>
															<ml:apply>
																<ml:id xml:space="preserve">MUT</ml:id>
																<ml:id xml:space="preserve">Pop1</ml:id>
															</ml:apply>
															<ml:id xml:space="preserve">Pop2</ml:id>
														</ml:sequence>
													</ml:apply>
												</ml:sequence>
											</ml:apply>
										</ml:localDefine>
										<ml:localDefine>
											<ml:id xml:space="preserve">Fit</ml:id>
											<ml:apply>
												<ml:id xml:space="preserve">FITNESS</ml:id>
												<ml:sequence>
													<ml:id xml:space="preserve">Pop2</ml:id>
													<ml:id xml:space="preserve">Coord</ml:id>
												</ml:sequence>
											</ml:apply>
										</ml:localDefine>
										<ml:localDefine>
											<ml:id xml:space="preserve">Pop1</ml:id>
											<ml:apply>
												<ml:id xml:space="preserve">SELECTION</ml:id>
												<ml:sequence>
													<ml:id xml:space="preserve">Pop2</ml:id>
													<ml:id xml:space="preserve">Fit</ml:id>
													<ml:id xml:space="preserve">NOsob</ml:id>
												</ml:sequence>
											</ml:apply>
										</ml:localDefine>
									</ml:program>
								</ml:for>
								<ml:id xml:space="preserve">Pop1</ml:id>
							</ml:program>
						</ml:define>
					</math>
					<rendering item-idref="14"/>
				</region>
				<region region-id="286" left="1068" top="2234.25" width="165.75" height="114.75" align-x="1076.25" align-y="2244" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Сам генетический алгоритм:</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<sp count="3"/>-начальная популяция (случайная)</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">цикл{</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<sp count="3"/>-скрещевание</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<sp count="3"/>-мутация</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<sp count="3"/>-преспособленность</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<sp count="3"/>-отбор</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">}</p>
					</text>
				</region>
				<region region-id="285" left="534" top="2240.25" width="423.75" height="97.5" align-x="534" align-y="2250" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Входные данные:</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Coord — матрица координат городов.</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Epocha — количество эпох (поколений).</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>NOsob — количество особей в популяции.</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit"/>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Выходные данные:</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Pop1 — финальная популяция после всех эпох (наиболее приспособленные особи)</b>.</p>
					</text>
				</region>
			</area>
			<rendering item-idref="15"/>
		</region>
