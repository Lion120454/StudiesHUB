				<region region-id="270" left="528" top="1215" width="319.5" height="55.5" align-x="528" align-y="1224" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Входные данные:</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>O1, O2 — две особи (родители).</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit"/>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Выходные данные:</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>[O11, O22] — два потомка или 0, если скрещивание невозможно.</b>
						</p>
					</text>
				</region>
				<region region-id="271" left="24" top="1545" width="456.75" height="11.25" align-x="51.75" align-y="1554" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="0" margin-right="0" text-indent="inherit" text-align="left" list-style-type="inherit" tabs="inherit">
							<b>Скрещивание особей всей популяции, если ни одна пара не произвела потомства то 0</b>
						</p>
					</text>
				</region>
				<region region-id="181" left="36" top="1563" width="280.5" height="248.25" align-x="99.75" align-y="1572" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">CROSS</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">Pop1</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve">NOsob</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve">rows</ml:id>
										<ml:id xml:space="preserve">Pop1</ml:id>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve">Pop2</ml:id>
									<ml:real>0</ml:real>
								</ml:localDefine>
								<ml:for>
									<ml:id xml:space="preserve">i</ml:id>
									<ml:range>
										<ml:real>0</ml:real>
										<ml:apply>
											<ml:minus/>
											<ml:id xml:space="preserve">NOsob</ml:id>
											<ml:real>1</ml:real>
										</ml:apply>
									</ml:range>
									<ml:program>
										<ml:ifThen>
											<ml:apply>
												<ml:notEqual/>
												<ml:id xml:space="preserve">i</ml:id>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve">NOsob</ml:id>
													<ml:real>1</ml:real>
												</ml:apply>
											</ml:apply>
											<ml:program>
												<ml:localDefine>
													<ml:id xml:space="preserve">O1</ml:id>
													<ml:apply>
														<ml:indexer/>
														<ml:id xml:space="preserve">Pop1</ml:id>
														<ml:id xml:space="preserve">i</ml:id>
													</ml:apply>
												</ml:localDefine>
												<ml:localDefine>
													<ml:id xml:space="preserve">O2</ml:id>
													<ml:apply>
														<ml:indexer/>
														<ml:id xml:space="preserve">Pop1</ml:id>
														<ml:apply>
															<ml:plus/>
															<ml:id xml:space="preserve">i</ml:id>
															<ml:real>1</ml:real>
														</ml:apply>
													</ml:apply>
												</ml:localDefine>
											</ml:program>
										</ml:ifThen>
										<ml:ifThen>
											<ml:apply>
												<ml:equal/>
												<ml:id xml:space="preserve">i</ml:id>
												<ml:apply>
													<ml:minus/>
													<ml:id xml:space="preserve">NOsob</ml:id>
													<ml:real>1</ml:real>
												</ml:apply>
											</ml:apply>
											<ml:program>
												<ml:localDefine>
													<ml:id xml:space="preserve">O1</ml:id>
													<ml:apply>
														<ml:indexer/>
														<ml:id xml:space="preserve">Pop1</ml:id>
														<ml:apply>
															<ml:minus/>
															<ml:id xml:space="preserve">NOsob</ml:id>
															<ml:real>1</ml:real>
														</ml:apply>
													</ml:apply>
												</ml:localDefine>
												<ml:localDefine>
													<ml:id xml:space="preserve">O2</ml:id>
													<ml:apply>
														<ml:indexer/>
														<ml:id xml:space="preserve">Pop1</ml:id>
														<ml:real>0</ml:real>
													</ml:apply>
												</ml:localDefine>
											</ml:program>
										</ml:ifThen>
										<ml:localDefine>
											<ml:id xml:space="preserve">C</ml:id>
											<ml:apply>
												<ml:id xml:space="preserve">crossingover</ml:id>
												<ml:sequence>
													<ml:id xml:space="preserve">O1</ml:id>
													<ml:id xml:space="preserve">O2</ml:id>
												</ml:sequence>
											</ml:apply>
										</ml:localDefine>
										<ml:ifThen>
											<ml:apply>
												<ml:notEqual/>
												<ml:id xml:space="preserve">C</ml:id>
												<ml:real>0</ml:real>
											</ml:apply>
											<ml:program>
												<ml:ifThen>
													<ml:apply>
														<ml:notEqual/>
														<ml:id xml:space="preserve">Pop2</ml:id>
														<ml:real>0</ml:real>
													</ml:apply>
													<ml:localDefine>
														<ml:id xml:space="preserve">Pop2</ml:id>
														<ml:apply>
															<ml:id xml:space="preserve">stack</ml:id>
															<ml:sequence>
																<ml:id xml:space="preserve">Pop2</ml:id>
																<ml:id xml:space="preserve">C</ml:id>
															</ml:sequence>
														</ml:apply>
													</ml:localDefine>
												</ml:ifThen>
												<ml:ifThen>
													<ml:apply>
														<ml:equal/>
														<ml:id xml:space="preserve">Pop2</ml:id>
														<ml:real>0</ml:real>
													</ml:apply>
													<ml:localDefine>
														<ml:id xml:space="preserve">Pop2</ml:id>
														<ml:id xml:space="preserve">C</ml:id>
													</ml:localDefine>
												</ml:ifThen>
											</ml:program>
										</ml:ifThen>
									</ml:program>
								</ml:for>
								<ml:id xml:space="preserve">Pop2</ml:id>
							</ml:program>
						</ml:define>
