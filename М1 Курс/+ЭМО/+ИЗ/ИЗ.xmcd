				<region region-id="247" left="24" top="663" width="178.5" height="155.25" align-x="69.75" align-y="672" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">Shuffle</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">O</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve">n</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve">rows</ml:id>
										<ml:id xml:space="preserve">O</ml:id>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve">osob1</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve">ceil</ml:id>
										<ml:apply>
											<ml:id xml:space="preserve">rnd</ml:id>
											<ml:apply>
												<ml:minus/>
												<ml:id xml:space="preserve">n</ml:id>
												<ml:real>1</ml:real>
											</ml:apply>
										</ml:apply>
									</ml:apply>
								</ml:localDefine>
								<ml:localDefine>
									<ml:id xml:space="preserve">osob2</ml:id>
									<ml:id xml:space="preserve">osob1</ml:id>
								</ml:localDefine>
								<ml:while>
									<ml:apply>
										<ml:equal/>
										<ml:id xml:space="preserve">osob1</ml:id>
										<ml:id xml:space="preserve">osob2</ml:id>
