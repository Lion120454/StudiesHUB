																		</ml:apply>
																		<ml:id xml:space="preserve">T1</ml:id>
																		<ml:apply>
																			<ml:id xml:space="preserve">sub</ml:id>
																			<ml:sequence>
																				<ml:id xml:space="preserve">O2</ml:id>
																				<ml:apply>
																					<ml:plus/>
																					<ml:id xml:space="preserve">j</ml:id>
																					<ml:id xml:space="preserve">t</ml:id>
																				</ml:apply>
																				<ml:apply>
																					<ml:minus/>
																					<ml:id xml:space="preserve">n</ml:id>
																					<ml:real>1</ml:real>
