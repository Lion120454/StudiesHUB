																		<ml:apply>
																			<ml:id xml:space="preserve">sub</ml:id>
																			<ml:sequence>
																				<ml:id xml:space="preserve">O2</ml:id>
																				<ml:real>0</ml:real>
																				<ml:apply>
																					<ml:minus/>
																					<ml:id xml:space="preserve">j</ml:id>
