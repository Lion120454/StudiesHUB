				<region region-id="258" left="12" top="951" width="308.25" height="11.25" align-x="33.75" align-y="960" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Начальная популяция состоящая из случайных особей</b>
						</p>
					</text>
				</region>
				<region region-id="263" left="330" top="951" width="492" height="66.75" align-x="330" align-y="960" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Входные данные:</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>n — количество городов.</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>NOsob — количество особей в популяции.</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit"/>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Выходные данные:</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Pop — матрица популяции, каждая строка — особь (случайный порядок городов).</b>
						</p>
					</text>
				</region>
				<region region-id="257" left="18" top="969" width="208.5" height="51" align-x="114" align-y="978" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">NACHPOP</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">n</ml:id>
									<ml:id xml:space="preserve">NOsob</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:for>
									<ml:id xml:space="preserve">i</ml:id>
									<ml:range>
										<ml:real>0</ml:real>
										<ml:apply>
											<ml:minus/>
											<ml:id xml:space="preserve">NOsob</ml:id>
											<ml:real>1</ml:real>
										</ml:apply>
									</ml:range>
									<ml:localDefine>
										<ml:apply>
											<ml:indexer/>
											<ml:id xml:space="preserve">Pop</ml:id>
											<ml:id xml:space="preserve">i</ml:id>
										</ml:apply>
										<ml:apply>
											<ml:id xml:space="preserve">rndOsob</ml:id>
											<ml:id xml:space="preserve">n</ml:id>
										</ml:apply>
									</ml:localDefine>
								</ml:for>
								<ml:id xml:space="preserve">Pop</ml:id>
							</ml:program>
						</ml:define>
					</math>
					<rendering item-idref="7"/>
				</region>
				<region region-id="260" left="18" top="1035" width="218.25" height="11.25" align-x="39.75" align-y="1044" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Случайная мутация особей популяции</b>
						</p>
					</text>
				</region>
				<region region-id="259" left="18" top="1053" width="171.75" height="67.5" align-x="71.25" align-y="1062" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
						<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
							<ml:function>
								<ml:id xml:space="preserve">MUT</ml:id>
								<ml:boundVars>
									<ml:id xml:space="preserve">Pop1</ml:id>
								</ml:boundVars>
							</ml:function>
							<ml:program>
								<ml:localDefine>
									<ml:id xml:space="preserve">NOsob</ml:id>
									<ml:apply>
										<ml:id xml:space="preserve">rows</ml:id>
										<ml:id xml:space="preserve">Pop1</ml:id>
									</ml:apply>
								</ml:localDefine>
								<ml:for>
									<ml:id xml:space="preserve">i</ml:id>
									<ml:range>
										<ml:real>0</ml:real>
										<ml:apply>
											<ml:minus/>
											<ml:id xml:space="preserve">NOsob</ml:id>
											<ml:real>1</ml:real>
										</ml:apply>
									</ml:range>
									<ml:localDefine>
										<ml:apply>
											<ml:indexer/>
											<ml:id xml:space="preserve">Pop2</ml:id>
											<ml:id xml:space="preserve">i</ml:id>
										</ml:apply>
										<ml:apply>
											<ml:id xml:space="preserve">Shuffle</ml:id>
											<ml:apply>
												<ml:indexer/>
												<ml:id xml:space="preserve">Pop1</ml:id>
												<ml:id xml:space="preserve">i</ml:id>
											</ml:apply>
										</ml:apply>
									</ml:localDefine>
								</ml:for>
								<ml:id xml:space="preserve">Pop2</ml:id>
							</ml:program>
						</ml:define>
					</math>
					<rendering item-idref="8"/>
				</region>
				<region region-id="265" left="246" top="1053" width="446.25" height="45" align-x="246" align-y="1062" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<text use-page-width="false" push-down="false" lock-width="true">
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Входные данные:</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Pop1 — исходная популяция (матрица особей).</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Выходные данные:</b>
						</p>
						<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
							<b>Pop2 — популяция после мутации.</b>
						</p>
					</text>
				</region>
				<region region-id="267" left="24" top="1149" width="157.5" height="12.75" align-x="81.75" align-y="1158" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
					<math optimize="false" disable-calc="false">
